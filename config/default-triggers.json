      ],
      "keywords": [],
      "trigger_mode": "regex",
      "priority": 35,
      "precedes": [],
      "requires": ["writing-plans"],
      "description": "Step-by-step execution of an approved plan. Triggered by explicit plan-continuation language."
    },
